<!DOCTYPE html><html><head><title>Products</title><link rel="stylesheet" href="/css/style.css"></head><body>
<%- include('partials/navbar') %>
<div class="container" style="padding-top:6rem;">
  <h2>All Products</h2>
  <div class="grid grid-3">
    <% products.forEach(p => { %>
      <div class="product-card glass">
        <div class="product-thumb"><% if(p.image){ %><img src="<%= p.image.startsWith('http') ? p.image : '/uploads/' + p.image %>"><% } %></div>
        <div class="product-info"><h4><%= p.name %></h4><div class="price">€<%= p.price.toFixed(2) %></div></div>
        <a href="/product/<%= p.id %>" class="btn btn-sm btn-outline">View</a>
      </div>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>
</body></html>