<!DOCTYPE html><html><head><title>Products</title><link rel="stylesheet" href="/css/style.css"></head><body>
<%- include('partials/navbar') %>
<div class="page-header"><div class="container"><h2>Our Products</h2></div></div>
<div class="container"><div class="grid grid-3">
  <% products.forEach(p => { %><div class="product-card glass"><div class="product-thumb"><% if(p.image){ %><img src="<%= p.image.startsWith('http') ? p.image : '/uploads/' + p.image %>" style="width:100%;height:100%;object-fit:contain;"><% } %></div><div class="product-info"><h4><%= p.name %></h4><p class="text-muted" style="font-size:0.8rem;"><%= p.description.substring(0,60) %>...</p></div><div class="product-meta"><span class="price">€<%= p.price.toFixed(2) %></span><a href="/product/<%= p.id %>" class="btn btn-sm btn-outline">View</a></div></div><% }) %>
</div></div>
<%- include('partials/footer') %>
</body></html>