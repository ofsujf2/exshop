<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>Executive Shop</title><link rel="stylesheet" href="/css/style.css"></head><body>
<%- include('partials/navbar') %>
<section class="hero"><h1>Premium<br><span class="accent">Products</span></h1><p>Discover our curated collection.</p><a href="/products" class="btn">Shop Now</a></section>
<section class="products-grid"><% products.forEach(p => { %><div class="product-card"><div class="image-wrapper"><% if(p.image){ %><img src="<%= p.image.startsWith('http') ? p.image : '/uploads/' + p.image %>"><% } %></div><div class="card-body"><h3><%= p.name %></h3><p class="desc"><%= p.description.substring(0,80) %>...</p><div class="price">&euro;<%= p.price.toFixed(2) %></div><a href="/product/<%= p.id %>" class="btn">View</a></div></div><% }) %></section>
<%- include('partials/footer') %></body></html>