<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — Executive Shop</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/categories') %>

    <div class="product-detail">
        <div class="image-wrapper">
            <% if (product.image) { %><img class="main-image" src="/uploads/<%= product.image %>" alt="<%= product.name %>"><% } %>
        </div>
        <div class="product-info">
            <span class="category">Premium Product</span>
            <h1><%= product.name %></h1>
            <div class="rating-big">★★★★★ <span>4.9 (128 reviews)</span></div>
            <div class="price-tag">€<%= product.price.toFixed(2) %></div>
            <p class="description"><%= product.description %></p>
            <div class="product-features">
                <div class="feature">✓ Premium Quality</div>
                <div class="feature">✓ Fast Shipping</div>
                <div class="feature">✓ 30-Day Returns</div>
                <div class="feature">✓ Secure Payment</div>
            </div>
            <a href="/checkout/<%= product.id %>" class="btn-checkout-main">Proceed to Checkout →</a>
        
<% if (product.gallery) { 
    const images = JSON.parse(product.gallery);
    if (images.length > 0) { %>
    <div style="display:flex;gap:0.5rem;margin-top:1rem;flex-wrap:wrap;">
        <% images.forEach(img => { %>
        <img src="<%= img %>" style="width:80px;height:80px;object-fit:cover;border-radius:12px;cursor:pointer;" onclick="document.querySelector('.main-image').src='<%= img %>'">
        <% }) %>
    </div>
    <% }
} %>

    </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>