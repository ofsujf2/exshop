<!DOCTYPE html><html><head><title>Crypto Payment</title><link rel="stylesheet" href="/css/style.css"></head><body>
<%- include('partials/navbar') %>
<div class="container" style="padding-top:6rem; max-width:600px; margin:0 auto;">
  <div class="glass" style="padding:2rem;">
    <h2>Crypto Payment</h2>
    <p class="lead">Send exactly <strong>&euro;<%= product.price.toFixed(2) %></strong> to one of these wallets</p>
    <div class="glass-strong" style="text-align:center; padding:1rem; margin:1.5rem 0; background:linear-gradient(135deg, #1a1a2e, #16213e); color:#f0b90b; border-radius:16px;">
      <span style="font-size:2.5rem; font-weight:900; font-family:monospace;" id="timer">25:00</span><br>
      <small>Time remaining</small>
    </div>
    <div class="wallet-options">
      <div class="wallet-option selected" data-addr="bc1qqkl35zull7py2zt8fvugxh0hs6elarxuzwcmka" onclick="selectWallet(this, 'bc1qqkl35zull7py2zt8fvugxh0hs6elarxuzwcmka')"><span>BTC</span><code class="addr">bc1qqkl35zull7py2zt8fvugxh0hs6elarxuzwcmka</code></div>
      <div class="wallet-option" data-addr="0x0536b4264B1AaA26B5A97c3184692b25Fa7e1628" onclick="selectWallet(this, '0x0536b4264B1AaA26B5A97c3184692b25Fa7e1628')"><span>ETH</span><code class="addr">0x0536b4264B1AaA26B5A97c3184692b25Fa7e1628</code></div>
      <div class="wallet-option" data-addr="2tUKR6CrndRiFR5iaRYhHwgA6uG1dqNbAVFKwwhXpkWE" onclick="selectWallet(this, '2tUKR6CrndRiFR5iaRYhHwgA6uG1dqNbAVFKwwhXpkWE')"><span>SOL</span><code class="addr">2tUKR6CrndRiFR5iaRYhHwgA6uG1dqNbAVFKwwhXpkWE</code></div>
      <div class="wallet-option" data-addr="LSEjnWc4NTWz9s3Sy7KsNFPk6DakAJAkaX" onclick="selectWallet(this, 'LSEjnWc4NTWz9s3Sy7KsNFPk6DakAJAkaX')"><span>LTC</span><code class="addr">LSEjnWc4NTWz9s3Sy7KsNFPk6DakAJAkaX</code></div>
    </div>
    <div class="qr-box" style="display:flex; justify-content:center; margin:1rem 0;"><img id="qr-code" src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=bc1qqkl35zull7py2zt8fvugxh0hs6elarxuzwcmka" alt="QR" style="border-radius:12px;"></div>
    <div style="display:flex; gap:0.8rem; justify-content:center;">
      <button class="btn btn-outline btn-sm" onclick="copyAddress()">Copy Address</button>
      <a href="/checkout/<%= product.id %>" class="btn btn-ghost btn-sm">Back</a>
    </div>
  </div>
</div>
<script>
  let timeLeft = 25 * 60;
  setInterval(() => {
    const m = Math.floor(timeLeft/60).toString().padStart(2,'0');
    const s = (timeLeft%60).toString().padStart(2,'0');
    document.getElementById('timer').textContent = m + ':' + s;
    if (timeLeft <= 0) document.getElementById('timer').textContent = "EXPIRED";
    timeLeft--;
  }, 1000);

  let currentAddr = 'bc1qqkl35zull7py2zt8fvugxh0hs6elarxuzwcmka';
  function selectWallet(el, addr) {
    document.querySelectorAll('.wallet-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    currentAddr = addr;
    document.getElementById('qr-code').src = 'https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=' + encodeURIComponent(addr);
  }
  function copyAddress() {
    navigator.clipboard.writeText(currentAddr).then(() => alert('Copied!')).catch(() => prompt('Copy:', currentAddr));
  }
</script>
<%- include('partials/footer') %>
</body></html>