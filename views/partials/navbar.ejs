<nav class="navbar">
    <a href="/" class="logo"><img src="/uploads/logo.png" width="120" height="120" style="border-radius:16px;object-fit:cover;" alt="Logo"></a>
    
    

    <form action="/search" method="GET" style="display:flex;align-items:center;gap:0;">
        <input type="text" name="q" placeholder="Search products..." style="padding:0.5rem 1rem;border:2px solid rgba(0,0,0,0.08);border-radius:50px 0 0 50px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.85rem;outline:none;width:180px;">
        <button type="submit" style="background:#e91e63;color:white;border:none;border-radius:0 50px 50px 0;padding:0.5rem 0.8rem;cursor:pointer;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
    </form>

<div class="nav-links">
        <a href="/">Shop</a>
        <a href="mailto:contact@executiveshop.com">Contact</a>
        <% if (locals.user) { %>
        <a href="/messages">Messages</a>
        <a href="/profile">Profile</a>
        <a href="/logout" class="login-link" style="background:#666;">Logout</a>
        <% } else { %>
        <a href="/register">Register</a>
        <a href="/login" class="login-link">Login</a>
        <% } %>
    </div>

    


    <div class="lang-selector">
        <select onchange="changeLanguage(this.value)" style="padding:0.4rem 0.8rem;border-radius:50px;border:1px solid rgba(0,0,0,0.1);font-family:'Plus Jakarta Sans',sans-serif;font-size:0.8rem;cursor:pointer;background:white;">
            <option value="en">🇬🇧 EN</option>
            <option value="it">🇮🇹 IT</option>
            <option value="es">🇪🇸 ES</option>
            <option value="fr">🇫🇷 FR</option>
            <option value="de">🇩🇪 DE</option>
            <option value="ru">🇷🇺 RU</option>
        </select>
    </div>
    <script>
    let currentLang = localStorage.getItem('lang') || 'en';
    document.querySelector('.lang-selector select').value = currentLang;
    function changeLanguage(lang) {
        localStorage.setItem('lang', lang);
        location.reload();
    }
    async function translatePage() {
        const lang = localStorage.getItem('lang') || 'en';
        if (lang === 'en') return;
        try {
            const res = await fetch('/locales/' + lang + '.json');
            const dict = await res.json();
            document.querySelectorAll('[data-t]').forEach(el => {
                const key = el.getAttribute('data-t');
                if (dict[key]) el.textContent = dict[key];
            });
            document.querySelectorAll('[data-t-placeholder]').forEach(el => {
                const key = el.getAttribute('data-t-placeholder');
                if (dict[key]) el.placeholder = dict[key];
            });
        } catch(e) {}
    }
    translatePage();
    </script>

</nav>