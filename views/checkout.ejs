<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout — <%= product.name %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="checkout-page">
        <div class="checkout-progress">
            <div class="progress-step active"><div class="step-circle">1</div><span>Shipping</span></div>
            <div class="progress-line active"></div>
            <div class="progress-step active"><div class="step-circle">2</div><span>Payment</span></div>
            <div class="progress-line"></div>
            <div class="progress-step"><div class="step-circle">3</div><span>Done</span></div>
        </div>

        <div class="checkout-grid">
            <div class="checkout-form-wrapper">
                <form method="POST" action="/checkout/<%= product.id %>">
                    <div class="form-section">
                        <div class="section-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e91e63" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        </div>
                        <h3>Shipping Details</h3>
                        <div class="form-row">
                            <div class="input-group"><label>Full Name</label><input type="text" name="name" placeholder="John Doe" required></div>
                            <div class="input-group"><label>Email</label><input type="email" name="email" placeholder="john@email.com" required></div>
                        </div>
                        <div class="input-group"><label>Address</label><input type="text" name="address" placeholder="123 Main Street" required></div>
                        <div class="form-row">
                            <div class="input-group"><label>City</label><input type="text" name="city" placeholder="Milan" required></div>
                            <div class="input-group"><label>ZIP Code</label><input type="text" name="zip_code" placeholder="20100" required></div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e91e63" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        </div>
                        <h3>Payment</h3>
                        <p style="color:var(--text-secondary);margin-bottom:1rem;font-size:0.9rem;">You will be redirected to PayPal to complete your payment securely.</p>
                        
                        <button type="submit" class="btn-paypal">
                            <img src="https://img.icons8.com/color/48/paypal.png" height="24" alt="PayPal">
                            Pay with PayPal
                        </button>
                    </div>
                </form>
            </div>

            <div class="checkout-summary-wrapper">
                <div class="summary-card">
                    <h3>Order Summary</h3>
                    <div class="summary-product">
                        <div class="summary-img">
                            <% if (product.image) { %><img src="/uploads/<%= product.image %>" alt="<%= product.name %>"><% } %>
                        </div>
                        <div class="summary-details">
                            <strong><%= product.name %></strong>
                            <p><%= product.description.substring(0,60) %>...</p>
                        </div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-row"><span>Subtotal</span><span>€<%= product.price.toFixed(2) %></span></div>
                    <div class="summary-row"><span>Shipping</span><span class="free">FREE</span></div>
                    <div class="summary-divider"></div>
                    <div class="summary-total"><span>Total</span><span>€<%= product.price.toFixed(2) %></span></div>
                </div>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>

    <style>
    .btn-paypal {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        background: linear-gradient(135deg, #FFC439, #FFB347);
        color: #003087;
        padding: 1.1rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(255,196,57,0.3);
        transition: all 0.3s;
    }
    .btn-paypal:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255,196,57,0.5);
    }
    </style>
</body>
</html>