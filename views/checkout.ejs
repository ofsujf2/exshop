<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout — <%= product.name %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        .checkout-page { max-width: 1100px; margin: 2rem auto; padding: 0 2rem; }
        .checkout-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; }
        .checkout-form-wrapper { background: rgba(255,255,255,0.7); backdrop-filter: blur(25px); border-radius: 24px; padding: 2.5rem; }
        .checkout-form-wrapper h3 { font-size: 1.3rem; font-weight: 700; margin: 1.5rem 0 1rem; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .input-group { margin-bottom: 1rem; }
        .input-group label { display: block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #666; margin-bottom: 0.3rem; }
        .input-group input { width: 100%; padding: 1rem; border: 2px solid rgba(0,0,0,0.06); border-radius: 14px; font-size: 1rem; font-family: 'Plus Jakarta Sans', sans-serif; outline: none; }
        .input-group input:focus { border-color: #e91e63; }
        #paypal-button-container { margin-bottom: 1rem; min-height: 45px; }
        .btn-crypto-main { width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.6rem; background: linear-gradient(135deg, #1a1a2e, #16213e); color: #f0b90b; padding: 1.1rem; border-radius: 50px; font-weight: 700; font-size: 1rem; border: 1px solid rgba(240,185,11,0.3); cursor: pointer; margin-bottom: 1rem; }
        .crypto-list { display: none; margin-bottom: 1rem; }
        .crypto-list.show { display: block; }
        .crypto-option { width: 100%; display: flex; align-items: center; gap: 1rem; padding: 1rem; border-radius: 14px; font-weight: 600; border: 2px solid rgba(0,0,0,0.06); background: rgba(255,255,255,0.8); cursor: pointer; margin-bottom: 0.5rem; transition: all 0.2s; }
        .crypto-option:hover { border-color: #e91e63; }
        .crypto-option.selected { border-color: #2e7d32; background: rgba(46,125,50,0.05); }
        .crypto-icon { width: 36px; height: 36px; flex-shrink: 0; }
        .crypto-pay-btn { width: 100%; margin-top: 0.5rem; background: linear-gradient(135deg,#e91e63,#c2185b); color: white; border: none; padding: 1.1rem; border-radius: 50px; font-weight: 700; font-size: 1rem; cursor: pointer; }
        .crypto-pay-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .crypto-payment-box { display: none; background: #f7f7f9; border-radius: 16px; padding: 1.5rem; margin-top: 1rem; text-align: center; }
        .crypto-payment-box.show { display: block; }
        .crypto-payment-box img.qr { width: 180px; height: 180px; border-radius: 12px; margin-bottom: 1rem; }
        .crypto-amount { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.3rem; }
        .crypto-address-box { background: #fff; border: 1px solid rgba(0,0,0,0.08); padding: 0.8rem; border-radius: 10px; word-break: break-all; font-size: 0.8rem; font-family: monospace; margin: 0.8rem 0; }
        .crypto-status { font-weight: 700; padding: 0.6rem; border-radius: 10px; margin-top: 0.8rem; }
        .crypto-status.waiting { background: #fff3e0; color: #e65100; }
        .crypto-status.paid { background: #e8f5e9; color: #2e7d32; }
        .summary-card { background: rgba(255,255,255,0.7); backdrop-filter: blur(25px); border-radius: 20px; padding: 1.5rem; }
        .summary-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
        .summary-product { display: flex; gap: 0.8rem; margin-bottom: 1rem; }
        .summary-img { width: 50px; height: 50px; border-radius: 10px; background: linear-gradient(155deg, #fce4ec, #f8bbd0); display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .summary-img img { width: 70%; height: 70%; object-fit: contain; }
        .summary-details strong { font-size: 0.85rem; }
        .summary-details p { font-size: 0.72rem; color: #999; }
        .summary-divider { height: 1px; background: rgba(0,0,0,0.06); margin: 0.8rem 0; }
        .summary-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: #666; padding: 0.3rem 0; }
        .summary-total { display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: 800; padding-top: 0.5rem; }
        .free { color: #2e7d32; font-weight: 700; }
        @media (max-width: 768px) { .checkout-grid { grid-template-columns: 1fr; } .form-row { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="checkout-page">
        <div class="checkout-grid">
            <div class="checkout-form-wrapper">
                <h3>Shipping Details</h3>
                <form id="checkout-form">
                    <div class="form-row">
                        <div class="input-group"><label>Full Name</label><input type="text" name="name" placeholder="John Doe" required></div>
                        <div class="input-group"><label>Email</label><input type="email" name="email" placeholder="john@email.com" required></div>
                    </div>
                    <div class="input-group"><label>Address</label><input type="text" name="address" placeholder="123 Main Street" required></div>
                    <div class="form-row">
                        <div class="input-group"><label>City</label><input type="text" name="city" placeholder="Milan" required></div>
                        <div class="input-group"><label>ZIP Code</label><input type="text" name="zip_code" placeholder="20100" required></div>
                    </div>
                </form>

                <h3>Payment Method</h3>
                <!-- PayPal disabled -->

                <button type="button" class="btn-crypto-main" id="toggle-crypto-btn">
                    <span style="font-size:1.4rem;">₿</span> Pay with Crypto
                </button>

                <div class="crypto-list" id="crypto-list">
                    <div class="crypto-option" data-currency="bitcoin">
                        <img class="crypto-icon" src="https://cdn.jsdelivr.net/npm/cryptocurrency-icons@0.18.1/svg/color/btc.svg" alt="Bitcoin">
                        <div style="flex:1;"><strong>Bitcoin (BTC)</strong><br><span style="font-size:0.75rem;color:#999;">Network: Bitcoin</span></div>
                    </div>
                    <div class="crypto-option" data-currency="ethereum">
                        <img class="crypto-icon" src="https://cdn.jsdelivr.net/npm/cryptocurrency-icons@0.18.1/svg/color/eth.svg" alt="Ethereum">
                        <div style="flex:1;"><strong>Ethereum (ETH)</strong><br><span style="font-size:0.75rem;color:#999;">Network: ERC20</span></div>
                    </div>
                    <div class="crypto-option" data-currency="solana">
                        <img class="crypto-icon" src="https://cdn.jsdelivr.net/npm/cryptocurrency-icons@0.18.1/svg/color/sol.svg" alt="Solana">
                        <div style="flex:1;"><strong>Solana (SOL)</strong><br><span style="font-size:0.75rem;color:#999;">Network: Solana</span></div>
                    </div>
                    <div class="crypto-option" data-currency="litecoin">
                        <img class="crypto-icon" src="https://cdn.jsdelivr.net/npm/cryptocurrency-icons@0.18.1/svg/color/ltc.svg" alt="Litecoin">
                        <div style="flex:1;"><strong>Litecoin (LTC)</strong><br><span style="font-size:0.75rem;color:#999;">Network: Litecoin</span></div>
                    </div>
                    <button type="button" class="crypto-pay-btn" id="crypto-pay-btn" disabled>Select a currency</button>
                </div>

                <div class="crypto-payment-box" id="crypto-payment-box">
                    <div class="crypto-amount" id="crypto-amount"></div>
                    <img class="qr" id="crypto-qr" src="" alt="QR code">
                    <div class="crypto-address-box" id="crypto-address"></div>
                    <div class="crypto-status waiting" id="crypto-status">Waiting for payment…</div>
                </div>
            </div>

            <div class="checkout-summary-wrapper">
                <div class="summary-card">
                    <h3>Order Summary</h3>
                    <div class="summary-product">
                        <div class="summary-img"><% if (product.image) { %><img src="/uploads/<%= product.image %>" alt=""><% } %></div>
                        <div class="summary-details"><strong><%= product.name %></strong><p><%= product.description.substring(0,60) %>...</p></div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-row"><span>Subtotal</span><span>€<%= product.price.toFixed(2) %></span></div>
                    <div class="summary-row"><span>Shipping</span><span class="free">FREE</span></div>
                    <div class="summary-divider"></div>
                    <div class="summary-total"><span>Total</span><span>€<%= product.price.toFixed(2) %></span></div>
                </div>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>

    <script>
      window.__CHECKOUT__ = { productId: "<%= product.id %>" };
    </script>
    <script src="/js/checkout-client.js"></script>
</body>
</html>