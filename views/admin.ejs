<!DOCTYPE html><html><head><title>Admin</title><link rel="stylesheet" href="/css/style.css"></head><body>
<%- include('partials/navbar') %>
<div class="admin-container">
<h1>Dashboard</h1>
<h3>Add Product (Multi-Image)</h3>
<form method="POST" action="/admin/add-multi" enctype="multipart/form-data">
<input name="name" placeholder="Product Name" required>
<textarea name="description" placeholder="Description"></textarea>
<input name="price" type="number" step="0.01" placeholder="Price" required>
<select name="category"><% categories.forEach(c => { %><option value="<%= c %>"><%= c %></option><% }) %></select>
<input name="stock" type="number" value="100">
<label>Images (max 10)</label>
<input type="file" name="images" multiple accept="image/*">
<button class="btn" type="submit">Upload Product</button>
</form>
<h3>Products (<%= products.length %>)</h3>
<% products.forEach(p => { %><div style="display:flex;justify-content:space-between;padding:0.5rem;border-bottom:1px solid #eee;"><span><%= p.name %> - &euro;<%= p.price %></span><a href="/admin/delete/<%= p.id %>" style="color:red;">Delete</a></div><% }) %>
<a href="/logout" class="btn" style="background:#333;">Logout</a>
</div>
<%- include('partials/footer') %></body></html>