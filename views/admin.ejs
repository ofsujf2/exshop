<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard — Executive Shop</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="admin-container">
        <h1>Dashboard</h1>
        <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:2rem;">Complete control panel</p>

        <div class="stats-grid">
            <div class="stat-card"><div class="stat-icon" style="background:linear-gradient(135deg,#e91e63,#c2185b);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg></div><div><span class="stat-value"><%= products.length %></span><span class="stat-label">Products</span></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:linear-gradient(135deg,#2e7d32,#1b5e20);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></div><div><span class="stat-value"><%= orders.length %></span><span class="stat-label">Orders</span></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:linear-gradient(135deg,#f59e0b,#e65100);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div><div><span class="stat-value">€<%= orders.reduce((s,o)=>s+o.amount,0).toFixed(2) %></span><span class="stat-label">Revenue</span></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:linear-gradient(135deg,#1565c0,#0d47a1);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div><span class="stat-value"><%= orders.filter(o=>o.status==='pending').length %></span><span class="stat-label">Pending</span></div></div>
        </div>

        <div class="section-title">PayPal API Keys</div>
        <input type="text" id="paypal_client_id" placeholder="PayPal Client ID" value="<%= config ? config.paypal_client_id || '' : '' %>" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <input type="password" id="paypal_secret" placeholder="PayPal Secret" value="<%= config ? config.paypal_secret || '' : '' %>" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <button onclick="saveKeys()" class="btn-submit">Save & Verify Keys</button>
        <span id="api-status" style="margin-left:1rem;font-weight:600;font-size:0.85rem;"></span>
        <% if (config) { %><span style="margin-left:1rem;font-size:0.85rem;color:<%= config.paypal_verified ? '#2e7d32' : '#c62828' %>;"><%= config.paypal_verified ? '✅ Verified' : '❌ Not verified' %></span><% } %>

        <div class="section-title">Add Product</div>
        <form method="POST" action="/admin/add" enctype="multipart/form-data">
            <input type="text" name="name" placeholder="Product Name" required style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
            <textarea name="description" placeholder="Description" required style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);"></textarea>
            <div style="display:flex;gap:0.5rem;">
                <input type="number" step="0.01" name="price" placeholder="Price (€)" required style="flex:1;padding:0.8rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
                <input type="number" name="stock" placeholder="Stock" value="100" required style="flex:1;padding:0.8rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
            </div>
            <select name="category" style="width:100%;padding:0.8rem;margin:0.5rem 0;border-radius:14px;border:2px solid rgba(0,0,0,0.06);"><option>All</option><option>Gaming</option><option>Electronics</option><option>Robux</option><option>Clothes</option><option>Accessories</option><option>Adapters</option><option>Home</option><option>Garden</option></select>
            <input type="file" name="image" style="margin-bottom:0.5rem;">
            <button type="submit" class="btn-submit">Publish Product</button>
        </form>

        <div class="section-title">Catalog</div>
        <% products.forEach(p => { %>
        <div class="admin-item">
            <span><strong><%= p.name %></strong> — €<%= p.price.toFixed(2) %> | Stock: <%= p.stock || 'N/A' %> | <%= p.sales_count %>+ sold</span>
            <a href="/admin/delete/<%= p.id %>" class="btn-delete" onclick="return confirm('Delete?')">Remove</a>
        </div>
        <% }) %>
        <a href="/logout" class="btn-logout">Sign Out</a>
    </div>
    <%- include('partials/footer') %>
    <script>
    function saveKeys(){
        fetch('/admin/save-keys',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({paypal_client_id:document.getElementById('paypal_client_id').value,paypal_secret:document.getElementById('paypal_secret').value})}).then(r=>r.json()).then(d=>{document.getElementById('api-status').textContent=d.message;setTimeout(()=>location.reload(),1000)})
    }
    </script>
</body>
</html>