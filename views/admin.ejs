<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard — Executive Shop</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="admin-container">
        <h1>Dashboard</h1>
        
        <div class="section-title">Payment API Keys</div>
        <input type="text" id="paypal_client_id" placeholder="PayPal Client ID" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <input type="password" id="paypal_secret" placeholder="PayPal Secret" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <input type="password" id="stripe_secret_key" placeholder="Stripe Secret Key" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <input type="text" id="stripe_publishable_key" placeholder="Stripe Publishable Key" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <input type="password" id="coinbase_api_key" placeholder="Coinbase API Key" style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
        <button onclick="saveApiKeys()" class="btn-submit">Save API Keys</button>
        <span id="api-status"></span>

        <div class="section-title">Add Product</div>
        <form method="POST" action="/admin/add" enctype="multipart/form-data">
            <input type="text" name="name" placeholder="Product Name" required style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
            <textarea name="description" placeholder="Description" required style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);"></textarea>
            <input type="number" step="0.01" name="price" placeholder="Price" required style="width:100%;padding:0.8rem;margin-bottom:0.5rem;border-radius:14px;border:2px solid rgba(0,0,0,0.06);">
            <input type="file" name="image" style="margin-bottom:0.5rem;">
            <button type="submit" class="btn-submit">Publish</button>
        </form>

        <a href="/logout" class="btn-logout">Sign Out</a>
    </div>
    <script>
    function saveApiKeys(){
        const d={
            paypal_client_id:document.getElementById('paypal_client_id').value,
            paypal_secret:document.getElementById('paypal_secret').value,
            stripe_secret_key:document.getElementById('stripe_secret_key').value,
            stripe_publishable_key:document.getElementById('stripe_publishable_key').value,
            coinbase_api_key:document.getElementById('coinbase_api_key').value
        };
        fetch('/admin/save-keys',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)})
        .then(r=>r.json()).then(d=>{document.getElementById('api-status').textContent=d.message});
    }
    </script>
</body>
</html>