<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credit Card Payment — <%= product.name %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        .card-page { max-width: 500px; margin: 3rem auto; text-align: center; padding: 2rem; background: rgba(255,255,255,0.8); border-radius: 24px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
        .card-icon { margin-bottom: 1.5rem; }
        .card-amount { font-size: 2rem; font-weight: 800; color: #1a1a2e; margin: 1rem 0; }
        .card-number-box { background: linear-gradient(135deg, #1a1a2e, #2d2d44); color: white; padding: 2rem; border-radius: 16px; font-size: 1.3rem; letter-spacing: 2px; margin: 1.5rem 0; }
        .card-details { text-align: left; line-height: 2.2; color: #666; }
        .copy-btn { background: #1a1a2e; color: white; border: none; padding: 0.8rem 2rem; border-radius: 50px; font-weight: 700; cursor: pointer; font-size: 1rem; margin-top: 1rem; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="card-page">
        <div class="card-icon">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#1a1a2e" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <h2>Credit Card Recharge</h2>
        <div class="card-amount">€<%= product.price.toFixed(2) %></div>
        <div class="card-number-box">
            <div style="font-size:0.8rem;opacity:0.7;margin-bottom:0.5rem;">SEND PAYMENT TO THIS CARD NUMBER</div>
            4532 7891 4562 1038
        </div>
        <div class="card-details">
            <p><strong>Card Number:</strong> </p>
            <p><strong>Cardholder:</strong> EXECUTIVE SHOP</p>
            <p><strong>Bank:</strong> Revolut / Visa</p>
            <p><strong>Amount:</strong> €<%= product.price.toFixed(2) %></p>
            <p><strong>Reference:</strong> Order #<%= product.name.replace(/\s/g, '').substring(0,8).toUpperCase() %></p>
        </div>
        <button class="copy-btn" onclick="copyCard()">Copy Card Number</button>
        <br><br>
        <a href="/product/<%= product.id %>" style="color:#999;text-decoration:none;">← Back to product</a>
    </div>
    <%- include('partials/footer') %>
    <script>
    function copyCard() {
        navigator.clipboard.writeText('4532789145621038');
        alert('Card number copied! Send €<%= product.price.toFixed(2) %> via Revolut or bank transfer.');
    }
    </script>
</body>
</html>